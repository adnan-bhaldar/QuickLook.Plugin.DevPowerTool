<?xml version="1.0" encoding="utf-8"?>
<!--
    QuickLook.Plugin.DevPowerTool — QuickLook.Plugin.Metadata.config
    This file is copied to the build output directory by MSBuild
    (CopyToOutputDirectory=Always in the .csproj).
    QuickLook reads it to identify the plugin namespace and version.
-->
<Metadata>
  <Namespace>QuickLook.Plugin.DevPowerTool</Namespace>
  <Version>1</Version>
  <Description>Developer Power-User plugin: live colour swatches for CSS/SCSS/JSON/JS/TS config files, and privacy masking for .env files.</Description>
</Metadata>
