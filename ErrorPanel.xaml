<!--
    QuickLook.Plugin.DevPowerTool — ErrorPanel.xaml
    Minimal fallback displayed when the plugin encounters an error
    loading or rendering the file. Keeps QuickLook from crashing.
-->
<UserControl
    x:Class="QuickLook.Plugin.DevPowerTool.ErrorPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    d:DesignHeight="300" d:DesignWidth="600"
    Background="#1E1E2E">

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
            <TextBlock Text="⚠"
                       FontSize="40"
                       Foreground="#F5C518"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,12"/>
            <TextBlock Text="Preview Unavailable"
                       FontFamily="Segoe UI, sans-serif"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#CDD6F4"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>
            <TextBlock x:Name="ErrorMessageBlock"
                       Text=""
                       FontFamily="Cascadia Code, Consolas, monospace"
                       FontSize="12"
                       Foreground="#F38BA8"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="500"
                       TextAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
