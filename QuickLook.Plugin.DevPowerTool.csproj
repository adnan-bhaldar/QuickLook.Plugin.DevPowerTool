<?xml version="1.0" encoding="UTF-8" ?>
<!-- QuickLook.Plugin.DevPowerTool — QuickLook.Plugin.DevPowerTool.csproj
    Uses AvalonEdit — same editor as QuickLook's built-in TextViewer.
    All UI is pure code-behind (no .xaml files). -->
<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <OutputType>Library</OutputType>
        <TargetFramework>net462</TargetFramework>
        <RootNamespace>QuickLook.Plugin.DevPowerTool</RootNamespace>
        <AssemblyName>QuickLook.Plugin.DevPowerTool</AssemblyName>
        <Platforms>AnyCPU;x64</Platforms>
        <UseWPF>true</UseWPF>
        <UseWindowsForms>true</UseWindowsForms>
        <LangVersion>latest</LangVersion>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
        <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
        <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
        <GenerateTargetFrameworkAttribute>false</GenerateTargetFrameworkAttribute>
        <DebugType>full</DebugType>
        <Nullable>disable</Nullable>
        <CodeAnalysisRuleSet>MinimumRecommendedRules.ruleset</CodeAnalysisRuleSet>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
        <Optimize>false</Optimize>
        <OutputPath>bin\Debug\</OutputPath>
        <DefineConstants>DEBUG;TRACE</DefineConstants>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Configuration)' == 'Release'">
        <Optimize>true</Optimize>
        <OutputPath>bin\Release\</OutputPath>
        <DefineConstants>TRACE</DefineConstants>
    </PropertyGroup>
    <!-- Exclude QuickLook.Common submodule from this project's compile -->
    <ItemGroup>
        <Compile Remove="QuickLook.Common\**" />
        <EmbeddedResource Remove="QuickLook.Common\**" />
        <None Remove="QuickLook.Common\**" />
        <Page Remove="QuickLook.Common\**" />
    </ItemGroup>
    <!-- Exclude XAML files if they still exist on disk from old version -->
    <ItemGroup>
        <Page Remove="PreviewPanel.xaml" />
        <Page Remove="ErrorPanel.xaml" />
        <Compile Remove="PreviewPanel.xaml.cs" />
        <Compile Remove="ErrorPanel.xaml.cs" />
        <Compile Remove="Helpers\PreviewRenderer.cs" />
    </ItemGroup>
    <!-- AvalonEdit: same editor used by QuickLook's built-in TextViewer -->
    <ItemGroup>
        <PackageReference Include="AvalonEdit"
                          Version="6.3.0.90" />
    </ItemGroup>
    <!-- Plugin metadata: copied to output directory so QuickLook finds us -->
    <ItemGroup>
        <None Include="QuickLook.Plugin.Metadata.Base.config" />
        <None Include="QuickLook.Plugin.Metadata.config">
            <CopyToOutputDirectory>Always</CopyToOutputDirectory>
        </None>
    </ItemGroup>
    <!-- QuickLook.Common submodule -->
    <ItemGroup>
        <ProjectReference Include="QuickLook.Common\QuickLook.Common.csproj" />
    </ItemGroup>
</Project>