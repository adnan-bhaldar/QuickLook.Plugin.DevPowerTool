<!--
    QuickLook.Plugin.DevPowerTool — QuickLook.Plugin.DevPowerTool.csproj

    Targets net462 (same as HelloWorld) so it works with the
    QuickLook.Common submodule and the installed QuickLook runtime.
    UseWPF=true enables XAML compilation.
-->
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Library</OutputType>
    <TargetFramework>net462</TargetFramework>
    <RootNamespace>QuickLook.Plugin.DevPowerTool</RootNamespace>
    <AssemblyName>QuickLook.Plugin.DevPowerTool</AssemblyName>
    <Platforms>AnyCPU;x64</Platforms>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <LangVersion>latest</LangVersion>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <!-- Must be false; we supply our own Properties/AssemblyInfo.cs -->
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <GenerateTargetFrameworkAttribute>false</GenerateTargetFrameworkAttribute>
    <DebugType>full</DebugType>
    <Nullable>disable</Nullable>
    <CodeAnalysisRuleSet>MinimumRecommendedRules.ruleset</CodeAnalysisRuleSet>
  </PropertyGroup>

  <!-- Debug build -->
  <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
    <Optimize>false</Optimize>
    <OutputPath>bin\Debug\</OutputPath>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
  </PropertyGroup>

  <!-- Release build -->
  <PropertyGroup Condition="'$(Configuration)' == 'Release'">
    <Optimize>true</Optimize>
    <OutputPath>bin\Release\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
  </PropertyGroup>

  <!-- Exclude QuickLook.Common submodule sources from our build targets
       (the submodule has its own project file that we reference below) -->
  <ItemGroup>
    <Compile          Remove="QuickLook.Common\**" />
    <EmbeddedResource Remove="QuickLook.Common\**" />
    <None             Remove="QuickLook.Common\**" />
    <Page             Remove="QuickLook.Common\**" />
  </ItemGroup>

  <!-- Plugin metadata files -->
  <ItemGroup>
    <!-- Base config is a template — not copied to output -->
    <None Include="QuickLook.Plugin.Metadata.Base.config" />
    <!-- The generated config IS copied to output (required by QuickLook) -->
    <None Include="QuickLook.Plugin.Metadata.config">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <!-- Reference QuickLook.Common via the git submodule project -->
  <ItemGroup>
    <ProjectReference Include="QuickLook.Common\QuickLook.Common.csproj" />
  </ItemGroup>

</Project>
