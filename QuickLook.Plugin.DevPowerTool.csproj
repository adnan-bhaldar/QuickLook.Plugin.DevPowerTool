<?xml version="1.0" encoding="UTF-8" ?>
<!-- QuickLook.Plugin.DevPowerTool — QuickLook.Plugin.DevPowerTool.csproj

    Targets net462. UseWPF=true for WPF type resolution.
    All UI is pure code-behind (no .xaml files) to avoid
    x:Name / InitializeComponent generation issues in CI. -->
<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <OutputType>Library</OutputType>
        <TargetFramework>net462</TargetFramework>
        <RootNamespace>QuickLook.Plugin.DevPowerTool</RootNamespace>
        <AssemblyName>QuickLook.Plugin.DevPowerTool</AssemblyName>
        <Platforms>AnyCPU;x64</Platforms>
        <UseWPF>true</UseWPF>
        <UseWindowsForms>true</UseWindowsForms>
        <LangVersion>latest</LangVersion>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
        <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
        <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
        <GenerateTargetFrameworkAttribute>false</GenerateTargetFrameworkAttribute>
        <DebugType>full</DebugType>
        <Nullable>disable</Nullable>
        <CodeAnalysisRuleSet>MinimumRecommendedRules.ruleset</CodeAnalysisRuleSet>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
        <Optimize>false</Optimize>
        <OutputPath>bin\Debug\</OutputPath>
        <DefineConstants>DEBUG;TRACE</DefineConstants>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Configuration)' == 'Release'">
        <Optimize>true</Optimize>
        <OutputPath>bin\Release\</OutputPath>
        <DefineConstants>TRACE</DefineConstants>
    </PropertyGroup>
    <!-- Exclude QuickLook.Common submodule from this project's compile -->
    <ItemGroup>
        <Compile Remove="QuickLook.Common\**" />
        <EmbeddedResource Remove="QuickLook.Common\**" />
        <None Remove="QuickLook.Common\**" />
        <Page Remove="QuickLook.Common\**" />
    </ItemGroup>
    <!-- Explicitly exclude old XAML files if they still exist on disk -->
    <ItemGroup>
        <Page Remove="PreviewPanel.xaml" />
        <Page Remove="ErrorPanel.xaml" />
        <Compile Remove="PreviewPanel.xaml.cs" />
        <Compile Remove="ErrorPanel.xaml.cs" />
    </ItemGroup>
    <!-- Plugin metadata — copied to output so QuickLook can find the plugin -->
    <ItemGroup>
        <None Include="QuickLook.Plugin.Metadata.Base.config" />
        <None Include="QuickLook.Plugin.Metadata.config">
            <CopyToOutputDirectory>Always</CopyToOutputDirectory>
        </None>
    </ItemGroup>
    <!-- Reference QuickLook.Common via the git submodule -->
    <ItemGroup>
        <ProjectReference Include="QuickLook.Common\QuickLook.Common.csproj" />
    </ItemGroup>
</Project>